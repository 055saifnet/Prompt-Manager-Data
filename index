<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Prompt Manager 2026</title>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=Tajawal:wght@300;400;500;700&display=swap" rel="stylesheet">
<style>
  :root {
    --bg:#0d0f14;--surface:#13161e;--surface2:#1a1e2a;--surface3:#222736;
    --border:#2a2f3e;--border2:#353c52;
    --accent:#4f9cf9;--accent2:#7b61ff;--accent-glow:rgba(79,156,249,0.18);
    --green:#36d97b;--red:#ff4f4f;--yellow:#f9c94f;
    --text:#e8ecf4;--text2:#8891a8;--text3:#555f76;
    --radius:10px;--radius-sm:6px;
    --mono:'IBM Plex Mono',monospace;--sans:'Tajawal',sans-serif;
    --transition:0.18s cubic-bezier(.4,0,.2,1);
  }
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
  html,body{height:100%;font-family:var(--sans);background:var(--bg);color:var(--text);font-size:15px}
  ::-webkit-scrollbar{width:5px}::-webkit-scrollbar-track{background:transparent}::-webkit-scrollbar-thumb{background:var(--border2);border-radius:10px}
  .app{display:flex;height:100vh;overflow:hidden}
  .sidebar{width:240px;min-width:240px;background:var(--surface);border-left:1px solid var(--border);display:flex;flex-direction:column;overflow:hidden}
  .sidebar-header{padding:18px 16px 12px;border-bottom:1px solid var(--border)}
  .app-logo{display:flex;align-items:center;gap:10px;margin-bottom:14px}
  .logo-icon{width:34px;height:34px;background:linear-gradient(135deg,var(--accent),var(--accent2));border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0}
  .logo-text{font-size:14px;font-weight:700;color:var(--text)}
  .logo-sub{font-size:10px;color:var(--text3);font-family:var(--mono)}
  .gsheet-btn{width:100%;padding:8px 10px;background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius-sm);color:var(--text2);font-family:var(--sans);font-size:12px;cursor:pointer;display:flex;align-items:center;gap:7px;transition:all var(--transition)}
  .gsheet-btn:hover{border-color:var(--accent);color:var(--accent)}
  .gsheet-btn.connected{border-color:var(--green);color:var(--green);background:rgba(54,217,123,0.08)}
  .gsheet-label{flex:1}
  .sync-dot{width:6px;height:6px;border-radius:50%;background:var(--text3);flex-shrink:0;transition:background var(--transition)}
  .sync-dot.synced{background:var(--green)}
  .sync-dot.syncing{background:var(--accent);animation:pulse .8s infinite}
  .sync-dot.error{background:var(--red)}
  @keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}
  .sheet-link{display:none;margin-top:6px;font-size:10px;color:var(--text3);text-decoration:none;font-family:var(--mono);transition:color var(--transition);text-align:center}
  .sheet-link:hover{color:var(--accent)}
  .sidebar-search{padding:10px 16px;border-bottom:1px solid var(--border)}
  .search-input{width:100%;padding:7px 10px;background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius-sm);color:var(--text);font-family:var(--sans);font-size:13px;outline:none;transition:border-color var(--transition)}
  .search-input:focus{border-color:var(--accent)}
  .search-input::placeholder{color:var(--text3)}
  .groups-section{flex:1;overflow-y:auto;padding:10px 0}
  .groups-title{padding:4px 16px 6px;font-size:10px;letter-spacing:1.2px;color:var(--text3);font-family:var(--mono);text-transform:uppercase;display:flex;align-items:center;justify-content:space-between}
  .add-group-btn{background:none;border:none;cursor:pointer;color:var(--text3);width:20px;height:20px;display:flex;align-items:center;justify-content:center;border-radius:4px;transition:all var(--transition)}
  .add-group-btn:hover{color:var(--accent);background:var(--accent-glow)}
  .group-item{display:flex;align-items:center;padding:7px 16px;cursor:pointer;transition:all var(--transition);gap:8px;position:relative}
  .group-item:hover{background:var(--surface2)}
  .group-item.active{background:var(--accent-glow)}
  .group-item.active::before{content:'';position:absolute;right:0;top:25%;bottom:25%;width:3px;background:var(--accent);border-radius:2px 0 0 2px}
  .group-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
  .group-name{flex:1;font-size:13px;color:var(--text2)}
  .group-item.active .group-name{color:var(--accent);font-weight:500}
  .group-count{font-size:10px;color:var(--text3);font-family:var(--mono);background:var(--surface3);padding:1px 5px;border-radius:10px}
  .group-actions{display:none;gap:2px}
  .group-item:hover .group-actions{display:flex}
  .group-action-btn{background:none;border:none;cursor:pointer;color:var(--text3);width:18px;height:18px;display:flex;align-items:center;justify-content:center;border-radius:3px;transition:all var(--transition)}
  .group-action-btn:hover{color:var(--red);background:rgba(255,79,79,0.1)}
  .main{flex:1;display:flex;flex-direction:column;overflow:hidden}
  .setup-screen{flex:1;display:flex;align-items:center;justify-content:center;padding:40px}
  .setup-card{background:var(--surface);border:1px solid var(--border);border-radius:16px;padding:32px;max-width:460px;width:100%;text-align:center}
  .setup-icon{font-size:40px;margin-bottom:12px}
  .setup-title{font-size:18px;font-weight:700;margin-bottom:8px}
  .setup-desc{font-size:13px;color:var(--text2);line-height:1.7;margin-bottom:22px}
  .setup-steps{text-align:right;margin-bottom:22px}
  .setup-step{display:flex;align-items:flex-start;gap:10px;margin-bottom:10px;font-size:13px;color:var(--text2)}
  .step-num{width:20px;height:20px;border-radius:50%;background:var(--accent-glow);border:1px solid var(--accent);color:var(--accent);font-size:11px;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-family:var(--mono);margin-top:1px}
  .setup-btn{width:100%;padding:12px;background:linear-gradient(135deg,var(--accent),var(--accent2));border:none;border-radius:var(--radius-sm);color:#fff;font-family:var(--sans);font-size:14px;font-weight:600;cursor:pointer;box-shadow:0 2px 16px rgba(79,156,249,0.3);transition:opacity var(--transition)}
  .setup-btn:hover{opacity:0.9}
  .setup-note{font-size:11px;color:var(--text3);margin-top:10px;font-family:var(--mono)}
  .topbar{padding:16px 24px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:12px}
  .topbar-title{font-size:16px;font-weight:700;flex:1}
  .topbar-count{font-size:12px;color:var(--text3);font-family:var(--mono)}
  .add-note-btn{padding:8px 16px;background:linear-gradient(135deg,var(--accent),var(--accent2));border:none;border-radius:var(--radius-sm);color:#fff;font-family:var(--sans);font-size:13px;font-weight:500;cursor:pointer;display:flex;align-items:center;gap:6px;transition:opacity var(--transition);box-shadow:0 2px 12px rgba(79,156,249,0.25)}
  .add-note-btn:hover{opacity:0.9}
  .cards-area{flex:1;overflow-y:auto;padding:20px 24px}
  .cards-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));gap:16px}
  .card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;transition:border-color var(--transition),box-shadow var(--transition);display:flex;flex-direction:column}
  .card:hover{border-color:var(--border2);box-shadow:0 4px 24px rgba(0,0,0,0.3)}
  .card-header{padding:14px 16px 10px;display:flex;align-items:flex-start;gap:10px}
  .card-title-wrap{flex:1}
  .card-title{font-size:14px;font-weight:600;line-height:1.4;color:var(--text)}
  .card-badge{display:inline-block;margin-top:5px;padding:2px 8px;border-radius:20px;font-size:10px;font-family:var(--mono);border:1px solid}
  .card-actions{display:flex;gap:4px;flex-shrink:0}
  .card-btn{width:28px;height:28px;background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius-sm);cursor:pointer;color:var(--text3);display:flex;align-items:center;justify-content:center;transition:all var(--transition)}
  .card-btn:hover{border-color:var(--accent);color:var(--accent);background:var(--accent-glow)}
  .card-btn.delete:hover{border-color:var(--red);color:var(--red);background:rgba(255,79,79,0.08)}
  .card-desc{padding:0 16px 12px;font-size:13px;color:var(--text2);line-height:1.6}
  .card-accordion{border-top:1px solid var(--border)}
  .accordion-toggle{width:100%;padding:9px 16px;background:none;border:none;cursor:pointer;display:flex;align-items:center;gap:8px;color:var(--text3);font-family:var(--sans);font-size:12px;transition:color var(--transition)}
  .accordion-toggle:hover{color:var(--accent)}
  .accordion-toggle svg{transition:transform var(--transition)}
  .accordion-toggle.open svg{transform:rotate(180deg)}
  .accordion-toggle.open{color:var(--accent)}
  .accordion-toggle-text{flex:1;text-align:right}
  .accordion-body{display:none;padding:12px 16px;background:var(--surface2);border-top:1px solid var(--border);position:relative}
  .accordion-body.open{display:block}
  .code-content{font-family:var(--mono);font-size:12px;color:#c8d3f5;white-space:pre-wrap;word-break:break-word;line-height:1.7;max-height:220px;overflow-y:auto}
  .copy-btn{position:absolute;top:10px;left:10px;padding:5px 10px;background:var(--surface3);border:1px solid var(--border2);border-radius:var(--radius-sm);cursor:pointer;color:var(--text2);font-family:var(--mono);font-size:11px;display:flex;align-items:center;gap:5px;transition:all var(--transition)}
  .copy-btn:hover{border-color:var(--accent);color:var(--accent)}
  .copy-btn.copied{border-color:var(--green);color:var(--green);background:rgba(54,217,123,0.1)}
  .empty-state{grid-column:1/-1;padding:60px 20px;text-align:center;color:var(--text3)}
  .empty-state svg{margin:0 auto 16px;opacity:.3;display:block}
  .empty-state h3{font-size:16px;color:var(--text2);margin-bottom:6px}
  .empty-state p{font-size:13px}
  .modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.6);backdrop-filter:blur(4px);z-index:100;align-items:center;justify-content:center}
  .modal-overlay.open{display:flex}
  .modal{background:var(--surface);border:1px solid var(--border2);border-radius:14px;padding:24px;width:90%;max-width:520px;box-shadow:0 20px 60px rgba(0,0,0,0.5);animation:modalIn .2s cubic-bezier(.34,1.56,.64,1)}
  @keyframes modalIn{from{opacity:0;transform:scale(.95) translateY(10px)}to{opacity:1;transform:none}}
  .modal-title{font-size:16px;font-weight:700;margin-bottom:20px}
  .form-group{margin-bottom:14px}
  .form-label{display:block;font-size:12px;color:var(--text3);margin-bottom:5px;font-family:var(--mono)}
  .form-input,.form-textarea,.form-select{width:100%;padding:9px 12px;background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius-sm);color:var(--text);font-family:var(--sans);font-size:13px;outline:none;transition:border-color var(--transition)}
  .form-input:focus,.form-textarea:focus,.form-select:focus{border-color:var(--accent)}
  .form-textarea{min-height:80px;resize:vertical;line-height:1.6}
  .form-textarea.code{font-family:var(--mono);font-size:12px;min-height:120px}
  .form-select option{background:var(--surface2)}
  .modal-actions{display:flex;gap:8px;margin-top:20px}
  .btn-primary{padding:9px 20px;background:linear-gradient(135deg,var(--accent),var(--accent2));border:none;border-radius:var(--radius-sm);color:#fff;font-family:var(--sans);font-size:13px;font-weight:500;cursor:pointer;transition:opacity var(--transition)}
  .btn-primary:hover{opacity:0.9}
  .btn-secondary{padding:9px 20px;background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius-sm);color:var(--text2);font-family:var(--sans);font-size:13px;cursor:pointer;transition:all var(--transition)}
  .btn-secondary:hover{border-color:var(--border2);color:var(--text)}
  .toast-container{position:fixed;bottom:24px;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;gap:8px;z-index:200;pointer-events:none}
  .toast{padding:10px 18px;border-radius:30px;font-size:13px;display:flex;align-items:center;gap:8px;box-shadow:0 4px 20px rgba(0,0,0,0.4);animation:toastIn .25s cubic-bezier(.34,1.56,.64,1);white-space:nowrap}
  @keyframes toastIn{from{opacity:0;transform:translateY(12px) scale(.9)}to{opacity:1;transform:none}}
  .toast.success{background:var(--green);color:#0a1a12}
  .toast.info{background:var(--accent);color:#fff}
  .toast.error{background:var(--red);color:#fff}
  .toast.warn{background:var(--yellow);color:#1a1400}
  .loading-overlay{position:fixed;inset:0;background:rgba(13,15,20,0.85);z-index:300;display:none;align-items:center;justify-content:center;flex-direction:column;gap:16px}
  .loading-overlay.show{display:flex}
  .spinner{width:36px;height:36px;border:3px solid var(--border2);border-top-color:var(--accent);border-radius:50%;animation:spin .7s linear infinite}
  @keyframes spin{to{transform:rotate(360deg)}}
  .loading-text{font-size:13px;color:var(--text2);font-family:var(--mono)}
  #dashboard{display:none;flex:1;flex-direction:column;overflow:hidden}
</style>
</head>
<body>
<div class="app">
  <aside class="sidebar">
    <div class="sidebar-header">
      <div class="app-logo">
        <div class="logo-icon">📋</div>
        <div>
          <div class="logo-text">Prompt Manager</div>
          <div class="logo-sub">Google Sheets Sync</div>
        </div>
      </div>
      <button class="gsheet-btn" id="connectBtn" onclick="handleConnect()">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
          <rect x="5" y="2" width="13" height="17" rx="1.5" fill="#34a853" opacity=".8"/>
          <path d="M13 2v5h5" fill="none" stroke="#fff" stroke-width="1.5"/>
          <rect x="7" y="10" width="9" height="1.2" rx=".6" fill="#fff"/>
          <rect x="7" y="13" width="9" height="1.2" rx=".6" fill="#fff"/>
          <rect x="7" y="16" width="6" height="1.2" rx=".6" fill="#fff"/>
        </svg>
        <span class="gsheet-label" id="connectLabel">ربط Google Sheets</span>
        <div class="sync-dot" id="syncDot"></div>
      </button>
      <a class="sheet-link" id="sheetLink" href="#" target="_blank">فتح الشيت ↗</a>
    </div>
    <div class="sidebar-search">
      <input class="search-input" id="searchInput" placeholder="بحث..." oninput="handleSearch(this.value)">
    </div>
    <div class="groups-section">
      <div class="groups-title">
        <span>المجموعات</span>
        <button class="add-group-btn" onclick="openAddGroup()">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        </button>
      </div>
      <div id="groupsList"></div>
    </div>
  </aside>

  <main class="main">
    <div class="setup-screen" id="setupScreen">
      <div class="setup-card">
        <div class="setup-icon">📊</div>
        <div class="setup-title">ربط Google Sheets</div>
        <div class="setup-desc">اضغط الزر أدناه لتحميل بياناتك من Google Sheet المرتبط.</div>
        <div class="setup-steps">
          <div class="setup-step"><div class="step-num">1</div><span>تأكد أن الـ Google Sheet جاهز بورقتي Notes و Groups</span></div>
          <div class="setup-step"><div class="step-num">2</div><span>اضغط الزر أدناه لتحميل البيانات</span></div>
          <div class="setup-step"><div class="step-num">3</div><span>كل إضافة أو تعديل يُحفظ فوراً في الشيت</span></div>
        </div>
        <button class="setup-btn" onclick="handleConnect()">تحميل البيانات من Google Sheets ←</button>
        <div class="setup-note">يتصل مباشرة بـ Google Apps Script — مجاني بالكامل</div>
      </div>
    </div>

    <div id="dashboard">
      <div class="topbar">
        <div class="topbar-title" id="topbarTitle">الكل</div>
        <div class="topbar-count" id="topbarCount">0 ملاحظة</div>
        <button class="add-note-btn" onclick="openAddNote()">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          إضافة ملاحظة
        </button>
      </div>
      <div class="cards-area">
        <div class="cards-grid" id="cardsGrid"></div>
      </div>
    </div>
  </main>
</div>

<!-- NOTE MODAL -->
<div class="modal-overlay" id="noteModal">
  <div class="modal">
    <div class="modal-title" id="noteModalTitle">إضافة ملاحظة</div>
    <div class="form-group"><label class="form-label">العنوان *</label><input class="form-input" id="noteTitle" placeholder="عنوان الملاحظة..."></div>
    <div class="form-group"><label class="form-label">الوصف</label><textarea class="form-textarea" id="noteDesc" placeholder="وصف اختياري..."></textarea></div>
    <div class="form-group"><label class="form-label">المجموعة</label><select class="form-select" id="noteGroup"></select></div>
    <div class="form-group"><label class="form-label">الكود / النص</label><textarea class="form-textarea code" id="noteCode" placeholder="كود أو نص..."></textarea></div>
    <div class="modal-actions">
      <button class="btn-primary" onclick="saveNote()">حفظ</button>
      <button class="btn-secondary" onclick="closeModal('noteModal')">إلغاء</button>
    </div>
  </div>
</div>

<!-- GROUP MODAL -->
<div class="modal-overlay" id="groupModal">
  <div class="modal" style="max-width:360px">
    <div class="modal-title">مجموعة جديدة</div>
    <div class="form-group"><label class="form-label">الاسم *</label><input class="form-input" id="groupName" placeholder="اسم المجموعة..."></div>
    <div class="form-group"><label class="form-label">اللون</label>
      <select class="form-select" id="groupColor">
        <option value="#4f9cf9">أزرق</option><option value="#7b61ff">بنفسجي</option>
        <option value="#36d97b">أخضر</option><option value="#f9c94f">أصفر</option>
        <option value="#ff6b6b">أحمر</option><option value="#ff9f4f">برتقالي</option>
        <option value="#4fd9f9">سماوي</option>
      </select>
    </div>
    <div class="modal-actions">
      <button class="btn-primary" onclick="saveGroup()">إضافة</button>
      <button class="btn-secondary" onclick="closeModal('groupModal')">إلغاء</button>
    </div>
  </div>
</div>

<!-- RENAME GROUP MODAL -->
<div class="modal-overlay" id="renameGroupModal">
  <div class="modal" style="max-width:360px">
    <div class="modal-title">تعديل المجموعة</div>
    <div class="form-group"><label class="form-label">الاسم *</label><input class="form-input" id="renameGroupName" placeholder="اسم المجموعة..."></div>
    <div class="form-group"><label class="form-label">اللون</label>
      <select class="form-select" id="renameGroupColor">
        <option value="#4f9cf9">أزرق</option><option value="#7b61ff">بنفسجي</option>
        <option value="#36d97b">أخضر</option><option value="#f9c94f">أصفر</option>
        <option value="#ff6b6b">أحمر</option><option value="#ff9f4f">برتقالي</option>
        <option value="#4fd9f9">سماوي</option>
      </select>
    </div>
    <div class="modal-actions">
      <button class="btn-primary" onclick="saveRenameGroup()">حفظ</button>
      <button class="btn-secondary" onclick="closeModal('renameGroupModal')">إلغاء</button>
    </div>
  </div>
</div>

<div class="loading-overlay" id="loadingOverlay">
  <div class="spinner"></div>
  <div class="loading-text" id="loadingText">جارٍ التحميل...</div>
</div>
<div class="toast-container" id="toastContainer"></div>

<script>
// ══════════════════════════════════════════════
//  ضع رابط Apps Script هنا
// ══════════════════════════════════════════════
const APPS_SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbyz_zJIeXjcol6Kv2sI9x-ZFFHiUdZ1b6ZXbVxMX9rfeOcFPJKxab6-wKKcoUvaMOjp/exec';

const STORAGE_KEY = 'pm2026_connected';

let S = {
  groups: [{ id:'all', name:'الكل', color:'#4f9cf9' }],
  notes: [],
  activeGroup: 'all',
  searchQuery: '',
  editingNoteId: null,
  editingGroupId: null,
  connected: false
};

// ── APPS SCRIPT API ──
async function apiCall(params) {
  const url = new URL(APPS_SCRIPT_URL);
  Object.entries(params).forEach(([k,v]) => url.searchParams.append(k, v));
  const r = await fetch(url.toString());
  if (!r.ok) throw new Error('HTTP ' + r.status);
  const data = await r.json();
  if (data.error) throw new Error(data.error);
  return data;
}

async function apiPost(body) {
  const r = await fetch(APPS_SCRIPT_URL, {
    method: 'POST',
    body: JSON.stringify(body)
  });
  if (!r.ok) throw new Error('HTTP ' + r.status);
  const data = await r.json();
  if (data.error) throw new Error(data.error);
  return data;
}

// ── CONNECT ──
async function handleConnect() {
  if (S.connected) { await loadAllData(); return; }
  await loadAllData();
}

// ── LOAD ──
async function loadAllData() {
  showLoading('تحميل البيانات من Google Sheet...');
  setSyncDot('syncing');
  try {
    const data = await apiCall({ action: 'read' });
    S.groups = [{ id:'all', name:'الكل', color:'#4f9cf9' }];
    if (Array.isArray(data.groups)) {
      data.groups.filter(g=>g&&g.id).forEach(g=>S.groups.push(g));
    }
    S.notes = Array.isArray(data.notes) ? data.notes.filter(n=>n&&n.id) : [];
    S.connected = true;
    setSyncDot('synced');
    updateConnectUI();
    showDashboard();
    render();
    hideLoading();
    sessionStorage.setItem(STORAGE_KEY, '1');
  } catch(e) {
    hideLoading();
    setSyncDot('error');
    toast('خطأ في الاتصال: ' + e.message, 'error');
    showDashboard();
    render();
  }
}

// ── SHEET WRITES ──
async function sheetWrite(body) {
  setSyncDot('syncing');
  try {
    await apiPost(body);
    setSyncDot('synced');
  } catch(e) {
    setSyncDot('error');
    toast('خطأ في الحفظ: ' + e.message, 'error');
  }
}

function esc(s) { return s ? String(s).replace(/"/g,'""').replace(/\n/g,'\\n') : ''; }

// ── GROUPS ──
function openAddGroup() {
  if (!S.connected) { toast('اتصل بـ Google Sheet أولاً', 'warn'); return; }
  document.getElementById('groupName').value = '';
  openModal('groupModal');
}

async function saveGroup() {
  const name = document.getElementById('groupName').value.trim();
  if (!name) { toast('أدخل الاسم', 'error'); return; }
  const color = document.getElementById('groupColor').value;
  const g = { id:'g_'+Date.now(), name, color };
  S.groups.push(g);
  closeModal('groupModal');
  render();
  toast('✓ تمت الإضافة — جارٍ الحفظ', 'info');
  await sheetWrite({ action:'appendGroup', id:g.id, name:g.name, color:g.color });
}

function openRenameGroup(id) {
  const g = S.groups.find(g=>g.id===id);
  if (!g) return;
  S.editingGroupId = id;
  document.getElementById('renameGroupName').value = g.name;
  const sel = document.getElementById('renameGroupColor');
  for (let o of sel.options) o.selected = o.value===g.color;
  openModal('renameGroupModal');
}

async function saveRenameGroup() {
  const name = document.getElementById('renameGroupName').value.trim();
  if (!name) { toast('أدخل الاسم', 'error'); return; }
  const color = document.getElementById('renameGroupColor').value;
  const g = S.groups.find(g=>g.id===S.editingGroupId);
  if (g) { g.name=name; g.color=color; }
  closeModal('renameGroupModal');
  render();
  toast('✓ تم التعديل — جارٍ الحفظ', 'info');
  await sheetWrite({ action:'updateGroup', id:S.editingGroupId, name, color });
}

async function deleteGroup(id) {
  if (!confirm('حذف المجموعة وجميع ملاحظاتها؟')) return;
  S.groups = S.groups.filter(g=>g.id!==id);
  S.notes = S.notes.filter(n=>n.group!==id);
  if (S.activeGroup===id) S.activeGroup='all';
  render();
  toast('✓ تم الحذف — جارٍ المزامنة', 'info');
  await sheetWrite({ action:'deleteGroup', id });
}

function selectGroup(id) {
  S.activeGroup = id;
  S.searchQuery = '';
  document.getElementById('searchInput').value = '';
  render();
}

// ── NOTES ──
function openAddNote() {
  if (!S.connected) { toast('اتصل بـ Google Sheet أولاً', 'warn'); return; }
  S.editingNoteId = null;
  document.getElementById('noteModalTitle').textContent = 'إضافة ملاحظة';
  ['noteTitle','noteDesc','noteCode'].forEach(id=>document.getElementById(id).value='');
  populateGroupSelect(S.activeGroup!=='all' ? S.activeGroup : '');
  openModal('noteModal');
}

function openEditNote(id) {
  const n = S.notes.find(n=>n.id===id);
  if (!n) return;
  S.editingNoteId = id;
  document.getElementById('noteModalTitle').textContent = 'تعديل الملاحظة';
  document.getElementById('noteTitle').value = n.title;
  document.getElementById('noteDesc').value = n.desc||'';
  document.getElementById('noteCode').value = n.code||'';
  populateGroupSelect(n.group);
  openModal('noteModal');
}

function populateGroupSelect(sel) {
  const el = document.getElementById('noteGroup');
  el.innerHTML = '';
  S.groups.filter(g=>g.id!=='all').forEach(g=>{
    const o = document.createElement('option');
    o.value=g.id; o.textContent=g.name;
    if (g.id===sel) o.selected=true;
    el.appendChild(o);
  });
}

async function saveNote() {
  const title = document.getElementById('noteTitle').value.trim();
  if (!title) { toast('أدخل العنوان', 'error'); return; }
  const desc  = document.getElementById('noteDesc').value.trim();
  const code  = document.getElementById('noteCode').value.trim();
  const group = document.getElementById('noteGroup').value;
  const now   = Date.now().toString();
  let body, note;

  if (S.editingNoteId) {
    note = S.notes.find(n=>n.id===S.editingNoteId);
    if (note) { note.title=title; note.desc=desc; note.code=code; note.group=group; note.updated=now; }
    body = { action:'updateNote', id:note.id, title, desc, code, group, updated:now };
    toast('✓ تم التعديل — جارٍ الحفظ', 'info');
  } else {
    note = { id:'n_'+Date.now(), title, desc, code, group, created:now, updated:now };
    S.notes.push(note);
    body = { action:'appendNote', id:note.id, title, desc, code, group, created:now, updated:now };
    toast('✓ تمت الإضافة — جارٍ الحفظ', 'info');
  }
  closeModal('noteModal');
  render();
  await sheetWrite(body);
}

async function deleteNote(id) {
  if (!confirm('حذف هذه الملاحظة؟')) return;
  S.notes = S.notes.filter(n=>n.id!==id);
  render();
  toast('✓ تم الحذف — جارٍ المزامنة', 'info');
  await sheetWrite({ action:'deleteNote', id });
}

// ── SEARCH & FILTER ──
function handleSearch(q) { S.searchQuery=q.trim().toLowerCase(); render(); }

function getFiltered() {
  let notes = S.notes;
  if (S.activeGroup!=='all') notes=notes.filter(n=>n.group===S.activeGroup);
  if (S.searchQuery) {
    const q=S.searchQuery;
    notes=notes.filter(n=>
      n.title.toLowerCase().includes(q)||
      (n.desc&&n.desc.toLowerCase().includes(q))||
      (n.code&&n.code.toLowerCase().includes(q))
    );
  }
  return notes;
}

// ── RENDER ──
function render() { renderGroups(); renderCards(); renderTopbar(); }

function renderGroups() {
  const c = document.getElementById('groupsList');
  c.innerHTML = '';
  S.groups.forEach(g=>{
    const count = g.id==='all' ? S.notes.length : S.notes.filter(n=>n.group===g.id).length;
    const active = S.activeGroup===g.id;
    const d = document.createElement('div');
    d.className='group-item'+(active?' active':'');
    d.onclick=()=>selectGroup(g.id);
    d.innerHTML=`
      <div class="group-dot" style="background:${g.color}"></div>
      <span class="group-name">${eh(g.name)}</span>
      <span class="group-count">${count}</span>
      ${g.id!=='all'?`<div class="group-actions">
        <button class="group-action-btn" onclick="event.stopPropagation();openRenameGroup('${g.id}')" title="تعديل">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
        </button>
        <button class="group-action-btn" onclick="event.stopPropagation();deleteGroup('${g.id}')" title="حذف">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg>
        </button>
      </div>`:''}
    `;
    c.appendChild(d);
  });
}

function renderCards() {
  const grid = document.getElementById('cardsGrid');
  const notes = getFiltered();
  grid.innerHTML = '';
  if (!notes.length) {
    grid.innerHTML=`<div class="empty-state">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="9" y1="9" x2="15" y2="9"/><line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="12" y2="17"/></svg>
      <h3>${S.searchQuery?'لا نتائج':'لا توجد ملاحظات'}</h3>
      <p>${S.searchQuery?'جرّب كلمة أخرى':'اضغط + لإضافة ملاحظة جديدة'}</p>
    </div>`;
    return;
  }
  notes.forEach(n=>{
    const g=S.groups.find(g=>g.id===n.group);
    const color=g?g.color:'#4f9cf9';
    const gname=g?g.name:'';
    const hasCode=n.code&&n.code.trim();
    const card=document.createElement('div');
    card.className='card';
    card.innerHTML=`
      <div class="card-header">
        <div class="card-title-wrap">
          <div class="card-title">${hlh(n.title,S.searchQuery)}</div>
          ${gname?`<span class="card-badge" style="color:${color};border-color:${color}30;background:${color}12">${eh(gname)}</span>`:''}
        </div>
        <div class="card-actions">
          <button class="card-btn" onclick="openEditNote('${n.id}')" title="تعديل">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
          </button>
          <button class="card-btn delete" onclick="deleteNote('${n.id}')" title="حذف">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg>
          </button>
        </div>
      </div>
      ${n.desc?`<div class="card-desc">${hlh(n.desc,S.searchQuery)}</div>`:''}
      ${hasCode?`<div class="card-accordion">
        <button class="accordion-toggle" onclick="toggleAcc('acc${n.id}',this)">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
          <span class="accordion-toggle-text">عرض الكود</span>
        </button>
        <div class="accordion-body" id="acc${n.id}">
          <button class="copy-btn" onclick="copyCode('${n.id}',this)">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
            نسخ
          </button>
          <div class="code-content">${hlh(n.code,S.searchQuery)}</div>
        </div>
      </div>`:''}
    `;
    grid.appendChild(card);
  });
}

function renderTopbar() {
  const g=S.groups.find(g=>g.id===S.activeGroup);
  const notes=getFiltered();
  document.getElementById('topbarTitle').textContent=S.searchQuery?`"${S.searchQuery}"`:g?g.name:'الكل';
  document.getElementById('topbarCount').textContent=notes.length+' ملاحظة';
}

// ── UI UTILS ──
function showDashboard() {
  document.getElementById('setupScreen').style.display='none';
  document.getElementById('dashboard').style.display='flex';
}

function updateConnectUI() {
  document.getElementById('connectBtn').classList.add('connected');
  document.getElementById('connectLabel').textContent='Google Sheets ✓';
  setSyncDot('synced');
}

function setSyncDot(s) { document.getElementById('syncDot').className='sync-dot'+(s?' '+s:''); }
function showLoading(t) { document.getElementById('loadingText').textContent=t; document.getElementById('loadingOverlay').classList.add('show'); }
function hideLoading() { document.getElementById('loadingOverlay').classList.remove('show'); }

function toggleAcc(id,btn) {
  const open=document.getElementById(id).classList.toggle('open');
  btn.classList.toggle('open',open);
  btn.querySelector('.accordion-toggle-text').textContent=open?'إخفاء الكود':'عرض الكود';
}

function copyCode(id,btn) {
  const n=S.notes.find(n=>n.id===id);
  if (!n?.code) return;
  navigator.clipboard.writeText(n.code).then(()=>{
    btn.classList.add('copied');
    btn.innerHTML='<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg> تم النسخ!';
    setTimeout(()=>{
      btn.classList.remove('copied');
      btn.innerHTML='<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg> نسخ';
    },1800);
    toast('✓ تم النسخ','success');
  }).catch(()=>toast('فشل النسخ','error'));
}

function openModal(id) { document.getElementById(id).classList.add('open'); }
function closeModal(id) { document.getElementById(id).classList.remove('open'); }

document.querySelectorAll('.modal-overlay').forEach(o=>o.addEventListener('click',e=>{
  if(e.target===o) o.classList.remove('open');
}));
document.getElementById('noteTitle').addEventListener('keydown',e=>{if(e.key==='Enter')saveNote()});
document.getElementById('groupName').addEventListener('keydown',e=>{if(e.key==='Enter')saveGroup()});
document.getElementById('renameGroupName').addEventListener('keydown',e=>{if(e.key==='Enter')saveRenameGroup()});
document.addEventListener('keydown',e=>{
  if(e.key==='Escape') document.querySelectorAll('.modal-overlay.open').forEach(m=>m.classList.remove('open'));
  if((e.ctrlKey||e.metaKey)&&e.key==='n'){e.preventDefault();openAddNote();}
  if((e.ctrlKey||e.metaKey)&&e.key==='f'){e.preventDefault();document.getElementById('searchInput').focus();}
});

function toast(msg,type='info') {
  const c=document.getElementById('toastContainer'),t=document.createElement('div');
  t.className='toast '+type; t.textContent=msg; c.appendChild(t);
  setTimeout(()=>t.remove(),2800);
}

function eh(s){if(!s)return'';return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
function hlh(h,q){if(!q)return h;const s=q.replace(/[.*+?^${}()|[\]\\]/g,'\\$&');return h.replace(new RegExp(s,'gi'),m=>`<mark style="background:rgba(79,156,249,0.3);color:var(--accent);border-radius:2px;padding:0 1px">${m}</mark>`);}

// ── AUTO LOAD ──
(async()=>{
  render();
  showDashboard();
  await loadAllData();
})();
</script>
